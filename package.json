{
  "name": "customary",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "// ---- public ---- //": "//",
    "compile": "wireit",
    "build": "wireit",
    "test": "wireit",
    "// ---- make ---- //": "//",
    "dist": "wireit",
    "// ---- dev ---- //": "//",
    "dev": "wireit",
    "compile:watch": "wireit",
    "clean": "wireit",
    "// ---- command ---- //": "//",
    "dist:*": "wireit",
    "test:integration": "wireit",
    "// ---- help ---- //": "//",
    "help": "wireit"
  },
  "wireit": {
    "help": {
      "command": "echo WIREIT_LOGGER=metrics npm run dist"
    },
    "test": {
      "command": "npm run test:integration",
      "dependencies": [
        "compile"
      ]
    },
    "test:integration": {
      "dependencies": [
        "../customary-cookbook:test"
      ]
    },
    "dist": {
      "command": "npm run dist:*",
      "dependencies": [
        "clean:dist",
        "build"
      ]
    },
    "dist:*": {
      "dependencies": ["dist:bundles", "dist:library"]
    },
    "dist:bundles": {
      "help:command": "https://github.com/parcel-bundler/parcel/issues/2540#issuecomment-454172473",
      "command": "parcel build --log-level=info"
    },
    "dist:library": {
      "command": "npx webpack"
    },
    "clean:dist": {
      "command": "rimraf .dist .parcel-cache"
    },
    "build": {
      "command": "npm run compile",
      "dependencies": [
        "clean:src"
      ]
    },
    "compile": {
      "command": "tsc --build --pretty --verbose"
    },
    "clean": {
      "dependencies": [
        "clean:src"
      ]
    },
    "clean:src": {
      "command": "rimraf --glob src/**/*.{d.ts,js.map,js} --glob tsconfig.tsbuildinfo"
    },
    "dev": {
      "command": "npm run compile:watch",
      "service": true
    },
    "compile:watch": {
      "command": "tsc --build --pretty --verbose --watch",
      "service": true
    }
  },
  "dependencies": {
    "@lit/reactive-element": "2.1.2",
    "lit": "3.3.2",
    "lit-html": "3.3.2"
  },
  "devDependencies": {
    "@parcel/transformer-typescript-tsc": "2.16.4",
    "@parcel/transformer-typescript-types": "2.16.4",
    "@types/node": "25.6.0",
    "copy-webpack-plugin": "14.0.0",
    "parcel": "2.16.4",
    "remove-files-webpack-plugin": "1.5.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "webpack": "5.104.1",
    "webpack-cli": "7.0.2",
    "wireit": "0.14.12"
  },
  "imports": {
    "#customary/*.js": "./src/*.ts",
    "#customary/lit": "./src/lit/index.ts"
  },
  "help:main": "https://parceljs.org/features/targets/#library-targets",
  "target:bundle:customary.mjs": ".dist/bundled/customary.mjs",
  "target:bundle:customary-library.mjs": ".dist/bundled/customary-library.mjs",
  "targets": {
    "target:bundle:customary.mjs": {
      "source": "./src/now.ts",
      "context": "browser",
      "isLibrary": true,
      "optimize": false,
      "includeNodeModules": [
        "lit",
        "lit-element",
        "lit-html",
        "@lit/reactive-element"
      ],
      "sourceMap": {
        "inline": true
      }
    },
    "target:bundle:customary-library.mjs": {
      "source": "./src/index.ts",
      "context": "browser",
      "isLibrary": true,
      "optimize": false,
      "includeNodeModules": [
        "lit",
        "lit-element",
        "lit-html",
        "@lit/reactive-element"
      ],
      "sourceMap": {
        "inline": true
      }
    }
  },
  "@parcel/resolver-default": {
    "packageExports": true
  },
  "license": "MIT",
  "author": "Andre de Oliveira"
}
